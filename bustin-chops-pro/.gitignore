# ============================================
# BUSTIN' CHOPS - .gitignore
# ============================================

# Dependencies
node_modules/
vendor/

# Build outputs
dist/
build/
.cache/

# Environment files
.env
.env.local
.env.*.local

# IDE / Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.settings/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# Compiled files
*.css.map
*.js.map

# Package manager lock files (optional - uncomment if needed)
# package-lock.json
# yarn.lock

# Backup files
*.bak
*.backup

# Local development
.local/
